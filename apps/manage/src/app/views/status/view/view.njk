{% extends "views/layouts/main.njk" %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/details/macro.njk" import govukDetails %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/tag/macro.njk" import govukTag %}

{% macro statusTag(status) %}
    {% if status === "complete" %}
        {{ govukTag({text: "Complete", classes: "govuk-tag--green"}) }}
    {% elif status === "failed" %}
        {{ govukTag({text: "Failed", classes: "govuk-tag--red"}) }}
    {% elif status === "processing" %}
        {{ govukTag({text: "Processing", classes: "govuk-tag--blue"}) }}
    {% elif status === "queued" %}
        {{ govukTag({text: "Queued", classes: "govuk-tag--yellow"}) }}
    {% else %}
        {{ govukTag({text: "Waiting", classes: "govuk-tag--grey"}) }}
    {% endif %}
{% endmacro %}

{% macro stepSummary(title, step) %}
    {{ govukSummaryList({
        card: {
            title: {
                text: title
            }
        },
        rows: [
            {
                key: { text: "Status" },
                value: { html: statusTag(step.status) }
            },
            {
                key: { text: "Started at" },
                value: { text: step.startedAt or "–" }
            },
            {
                key: { text: "Completed at" },
                value: { text: step.completedAt or "–" }
            },
            {
                key: { text: "Invocation ID" },
                value: { text: step.invocationId or "–" }
            },
            {
                key: { text: "Error message" },
                value: { text: step.errorMessage or "–" }
            }
        ]
    }) }}
{% endmacro %}

{% block pageContent %}
    {% if actionSuccess and not actionWarning %}
        {{ govukNotificationBanner({
            type: "success",
            text: actionSuccess + " triggered successfully. This case is now in the queue to be processed. Refresh the page to see the latest status."
        }) }}
    {% elseif actionSuccess and actionWarning %}
        {{ govukNotificationBanner({
            text: actionWarning
        }) }}
    {% endif %}

    {% set migrationActions %}
        <p class="govuk-body">
            To trigger a migration step for a case, use the buttons below.
            Then refresh the page to see the status and any progress.
        </p>
        {{ govukNotificationBanner({
            text: "These actions will trigger immediately and will not adhere to any configured schedules."
        }) }}
        <div class="govuk-button-group">
            {% for action in actions %}
                <form method="post" action="/case/{{ caseReference | urlencode }}/migrate/{{ action.action }}">
                    {{ govukButton({
                        text: action.text,
                        classes: "govuk-button--secondary"
                    }) }}
                </form>
            {% endfor %}
        </div>
    {% endset %}
    {{ govukDetails({
        summaryText: "Migration actions",
        html: migrationActions
    }) }}

    {{ stepSummary("Data", dataStep) }}
    {{ stepSummary("Document list", documentListStep) }}
    {{ stepSummary("Documents", documentsStep) }}

    {{ govukSummaryList({
        card: {
            title: {
                text: "Documents status"
            },
            actions: {
                items: [
                    {
                        href: documentStatusSummary.detailsUrl,
                        text: "View detailed document status"
                    }
                ]
            }
        },
        rows: [
            {
                key: { text: "Total documents" },
                value: { text: documentStatusSummary.total }
            },
            {
                key: { text: "Complete" },
                value: { html: govukTag({text: (documentStatusSummary.complete) | string, classes: "govuk-tag--green"}) }
            },
            {
                key: { text: "Failed" },
                value: { html: govukTag({text: (documentStatusSummary.failed) | string, classes: "govuk-tag--red"}) if documentStatusSummary.failed > 0 else (documentStatusSummary.failed | string) }
            },
            {
                key: { text: "Processing" },
                value: { html: govukTag({text: (documentStatusSummary.processing) | string, classes: "govuk-tag--blue"}) if documentStatusSummary.processing > 0 else (documentStatusSummary.processing | string) }
            },
            {
                key: { text: "Queued" },
                value: { text: documentStatusSummary.queued }
            },
            {
                key: { text: "Waiting" },
                value: { text: documentStatusSummary.waiting }
            }
        ]
    }) }}

    {{ stepSummary("Validation", validationStep) }}

    <h2 class="govuk-heading-m">Validation outcome</h2>

    {{ govukSummaryList({
        rows: [
            {
                key: { text: "Data validated" },
                value: { text: "Yes" if dataValidated else ("No (see errors below)" if dataValidated === false else "–") }
            },
            {
                key: { text: "Documents validated" },
                value: { text: "Yes" if documentsValidated else ("No (see errors below)" if documentsValidated === false else "–") }
            }
        ]
    }) }}

    {% if dataValidationErrors.length > 0 %}
        {% set dataErrorRows = [] %}
        {% for error in dataValidationErrors %}
            {% set dataErrorRows = (dataErrorRows.push([
                { text: error.sourceModel },
                { text: error.sourceField },
                { text: error.error }
            ]), dataErrorRows) %}
        {% endfor %}
        {{ govukTable({
            caption: "Data validation errors",
            captionClasses: "govuk-table__caption--s",
            head: [
                { text: "Source model" },
                { text: "Source field" },
                { text: "Error" }
            ],
            rows: dataErrorRows
        }) }}
    {% endif %}

    {% if documentValidationErrors.length > 0 %}
        {% set docErrorRows = [] %}
        {% for error in documentValidationErrors %}
            {% set docErrorRows = (docErrorRows.push([
                { text: error.sourceModel },
                { text: error.sourceField },
                { text: error.error }
            ]), docErrorRows) %}
        {% endfor %}
        {{ govukTable({
            caption: "Document validation errors",
            captionClasses: "govuk-table__caption--s",
            head: [
                { text: "Source model" },
                { text: "Source field" },
                { text: "Error" }
            ],
            rows: docErrorRows
        }) }}
    {% endif %}
{% endblock %}

