{% extends "views/layouts/main.njk" %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/details/macro.njk" import govukDetails %}
{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/tag/macro.njk" import govukTag %}
{% from "govuk/components/pagination/macro.njk" import govukPagination %}
{% from "govuk/components/input/macro.njk" import govukInput %}

{% macro statusTag(status) %}
    {% if status === "complete" %}
        {{ govukTag({text: "Complete", classes: "govuk-tag--green"}) }}
    {% elif status === "failed" %}
        {{ govukTag({text: "Failed", classes: "govuk-tag--red"}) }}
    {% elif status === "processing" %}
        {{ govukTag({text: "Processing", classes: "govuk-tag--blue"}) }}
    {% elif status === "queued" %}
        {{ govukTag({text: "Queued", classes: "govuk-tag--yellow"}) }}
    {% else %}
        {{ govukTag({text: "Waiting", classes: "govuk-tag--grey"}) }}
    {% endif %}
{% endmacro %}

{% block pageContent %}
    {{ govukDetails({
        summaryText: "About this list",
        text: "Cases in this list have been added for migration. This is not an exhaustive list of all cases. They will be processed in case reference order, as per the configured schedule. To add more cases, or check the configuration, select the configure tab in the navigation bar."
    }) }}
    <form method="get" action="" class="govuk-!-margin-bottom-6">
        <div class="govuk-form-group">
            {{ govukInput({
                id: "search",
                name: "search",
                label: {
                    text: "Search by case reference"
                },
                value: search,
                classes: "govuk-input--width-20"
            }) }}
        </div>
        {{ govukButton({ text: "Search" }) }}
        {% if search %}
            <a href="?" class="govuk-link govuk-!-margin-left-2">Clear</a>
        {% endif %}
    </form>

    {% set tableRows = [] %}

    {% for item in items %}
        {% set tableRows = (tableRows.push([
            { html: '<a class="govuk-link" href="/case/' + item.caseReference + '">' + item.caseReference + '</a>' },
            { html: statusTag(item.dataStatus) },
            { html: statusTag(item.documentListStatus) },
            { html: statusTag(item.documentsStatus) },
            { html: statusTag(item.validationStatus) }
        ]), tableRows) %}
    {% endfor %}

    {{ govukTable({
        head: [
            { text: "Case Reference" },
            { text: "Data" },
            { text: "Document List" },
            { text: "Documents" },
            { text: "Validation" }
        ],
        rows: tableRows
    }) }}

    {% if pagination.items %}
        {{ govukPagination(pagination) }}
    {% endif %}
{% endblock %}