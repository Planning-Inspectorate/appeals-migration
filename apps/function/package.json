{
  "name": "appeals-migration-function",
  "version": "1.0.0",
  "description": "Function app for handling integrations",
  "main": "src/functions/*.ts",
  "type": "module",
  "scripts": {
    "dev-list-cases": "node src/dev/run-a-list-cases.ts",
    "dev-migrate-data": "node src/dev/run-b-migrate-data.ts",
    "dev-list-documents": "node src/dev/run-c-list-documents.ts",
    "dev-migrate-documents": "node src/dev/run-d-migrate-documents.ts",
    "dev-validate": "node src/dev/run-e-validate.ts",
    "dev-seed": "node src/dev/seed-dev.ts",
    "start": "func start",
    "prepare-package": "node src/package.ts",
    "test": "node --test"
  },
  "private": true,
  "dependencies": {
    "@azure/functions": "*",
    "@azure/service-bus": "*",
    "@azure/storage-blob": "*",
    "@pins/appeals-migration-database": "^0.0.0",
    "@pins/appeals-migration-lib": "^0.0.0",
    "@pins/manage-appeals-database": "^0.0.0",
    "@pins/odw-curated-database": "^0.0.0",
    "lodash.chunk": "*"
  },
  "imports": {
    "#pins/appeals-migration-lib/*": "./src/packages/appeals-migration-lib/*",
    "#pins/appeals-migration-database": "./src/packages/appeals-migration-database/src/index.ts",
    "#pins/appeals-migration-database/*": "./src/packages/appeals-migration-database/*",
    "#pins/manage-appeals-database": "./src/packages/manage-appeals-database/src/index.ts",
    "#pins/manage-appeals-database/*": "./src/packages/manage-appeals-database/*",
    "#pins/odw-curated-database": "./src/packages/odw-curated-database/src/index.ts",
    "#pins/odw-curated-database/*": "./src/packages/odw-curated-database/*"
  },
  "devDependencies": {
    "@types/lodash.chunk": "*"
  }
}
